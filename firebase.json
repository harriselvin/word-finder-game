{
  "hosting": {
    "site": "word-finder-leaderboard",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "database": {
    "rules": {
      "leaderboard": {
        ".read": true,
        "$entryId": {
          ".write": "newData.child('score').isNumber() && newData.child('name').isString()",
          ".validate": "newData.hasChildren(['name', 'score', 'category', 'timestamp'])"
        }
      }
    }
  }
}
